# Editar el archivo .env con tus credenciales

# Clave de API principal para el modelo LLM (Groq)
GROQ_API_KEY="tu_api_key_de_groq_aqui"

# Opcional: Clave para Gemini si se utilizara como fallback u otro componente
#GOOGLE_API_KEY="tu_api_key_de_google_aqui"

# Configuración de base de datos vectorial Qdrant
QDRANT_URL="http://localhost:6333"
QDRANT_KEY=""

# Opcional: Para evaluación y trazabilidad con LangSmith
LANGSMITH_API_KEY="tu_langsmith_api_key_aqui"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_PROJECT="muevera_test"
LANGSMITH_TRACING="true"

# Optimización de Memoria (Auto-detectado para GTX 1070/GPUs con <= 8GB VRAM)
QUANTIZATION_BITS=4          # 4 para GPUs <= 8GB, 8 para GPUs >= 12GB. Si no se define se auto-detecta.
LAZY_LOAD_MODEL=true         # Cargar el modelo en la primera consulta, no al inicio
MAX_IMAGE_SIZE=1024          # Redimensionar imágenes para disminuir el consumo de VRAM
BATCH_SIZE=4                 # Tamaño del batch al procesar y almacenar documentos
CLEAR_CACHE_AFTER_PROCESS=true # Vaciar cache de PyTorch CUDA tras procesar embeddings
