# Editar el archivo .env con tus credenciales

# Clave de API principal para el modelo LLM (Groq)
GROQ_API_KEY="tu_api_key_de_groq_aqui"

# Opcional: Clave para Gemini si se utilizara como fallback u otro componente
#GOOGLE_API_KEY="tu_api_key_de_google_aqui"

# Configuración de base de datos vectorial Qdrant Cloud
QDRANT_URL="https://tu_cluster_qdrant.io:6333"
QDRANT_KEY="tu_qdrant_api_key_aqui"

# Opcional: Para evaluación y trazabilidad con LangSmith
LANGSMITH_API_KEY="tu_langsmith_api_key_aqui"
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_PROJECT="muevera_test"
LANGSMITH_TRACING="true"
